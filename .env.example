# ComfyUI to Cinema4D Bridge - Environment Configuration
# Copy this file to .env and update with your actual paths

# ====================
# Application Paths
# ====================
PROJECT_ROOT=D:\Yambo Studio Dropbox\Admin\_studio-dashboard-app-dev\comfy-to-c4d
CINEMA4D_PYTHON_SCRIPTS=${PROJECT_ROOT}/scripts
COMFYUI_WORKFLOWS=${PROJECT_ROOT}/workflows
GENERATED_IMAGES_DIR=${PROJECT_ROOT}/images
LOGS_DIR=${PROJECT_ROOT}/logs

# ====================
# ComfyUI Integration
# ====================
COMFYUI_ROOT=D:/Comfy3D_WinPortable/ComfyUI
COMFYUI_IMAGE_OUTPUT_DIR=${PROJECT_ROOT}/images
COMFYUI_3D_OUTPUT_DIR=${COMFYUI_ROOT}/output/3D
COMFYUI_CHECKPOINTS=${COMFYUI_ROOT}/models/checkpoints
COMFYUI_LORAS=${COMFYUI_ROOT}/models/loras

# ====================
# Cinema4D Integration
# ====================
C4D_SCRIPTS_DIR=${PROJECT_ROOT}/scripts/c4d
C4D_FILES_PROJECT_DIR=${PROJECT_ROOT}/c4d

# ====================
# API Configuration
# ====================
COMFYUI_API_URL=http://127.0.0.1:8188
C4D_MCP_PORT=54321

# ====================
# 3D Viewer Settings
# ====================
VIEWER_BACKGROUND_COLOR=#1a1a1a
VIEWER_GRID_COLOR=#333333
VIEWER_GRID_OPACITY=0.3
VIEWER_MAX_MODELS_GRID=100
VIEWER_ENABLE_TEXTURES=true
VIEWER_ENABLE_SHADOWS=true