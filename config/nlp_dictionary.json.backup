      "name": "Formula",
      "constant": "c4d.Oformula",
      "keywords": [
        "formula",
        "math",
        "equation",
        "expression"
      ],
      "description": "Creates a formula-based object",
      "parameters": {
        "size": 200,
        "pos_x": 0,
