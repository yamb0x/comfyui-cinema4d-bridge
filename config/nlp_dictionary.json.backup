        "pos_y": 0,
        "pos_z": 0
      }
    },
    "torus": {
      "name": "Torus",
      "constant": "c4d.Otorus",
      "keywords": [
        "torus",
        "donut",
        "ring"
      ],
      "description": "Creates a torus primitive",
      "parameters": {
        "ring_radius": 100,
        "pipe_radius": 20,
        "ring_segments": 36,
        "pipe_segments": 18,
        "pos_x": 0,
        "pos_y": 0,
        "pos_z": 0
      }
    },
    "plane": {
      "name": "Plane",
      "constant": "c4d.Oplane",
      "keywords": [
