{
  "primitives": {
    "cube": {
      "name": "Cube",
      "constant": "c4d.Ocube",
      "keywords": [
        "cube",
        "box",
        "square",
        "block"
      ],
      "description": "Creates a cube primitive",
      "parameters": {
        "size_x": 200,
        "size_y": 200,
        "size_z": 200,
        "segments": 1,
        "pos_x": 0,
        "pos_y": 0,
        "pos_z": 0
      }
    },
    "sphere": {
      "name": "Sphere",
      "constant": "c4d.Osphere",
      "keywords": [
        "sphere",
        "ball",
        "orb",
        "globe"
      ],
      "description": "Creates a sphere primitive",
      "parameters": {
        "radius": 100,
        "segments": 24,
        "type": 0,
        "render_perfect": true,
        "pos_x": 0,
        "pos_y": 0,
        "pos_z": 0
      }
    },
    "cylinder": {
      "name": "Cylinder",
      "constant": "c4d.Ocylinder",
