      ],
      "description": "Creates a plane primitive",
      "parameters": {
        "width": 400,
        "height": 400,
        "width_segments": 1,
        "height_segments": 1,
        "pos_x": 0,
        "pos_y": 0,
        "pos_z": 0
      }
    },
    "disc": {
      "name": "Disc",
      "constant": "c4d.Odisc",
      "keywords": [
